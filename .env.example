# OpenCode Go remote models (secret — required for remote/deepseek-v4-pro and remote/kimi-k2-6)
OPENCODE_API_KEY=

# Tavily deep research (optional unless deep_research provider is tavily)
TAVILY_API_KEY=

# Optional path to structured settings (default: ./settings.json)
# SETTINGS_JSON_PATH=./settings.json

# Qdrant vector DB (RAG). Overrides settings.json qdrant.url when set.
# Local Docker: http://localhost:6333 — LAN host example below:
QDRANT_URL=http://192.168.0.240:6333

# LiteLLM proxy config path (default: ./litellm_config.yaml)
# LITELLM_CONFIG_PATH=./litellm_config.yaml

# Project folders (default: ./projects at repo root)
PROJECTS_DIR=./projects

# Legacy data root (upload temp files; old projects may live under ./data/projects)
DATA_DIR=./data

# --- Legacy LM Studio settings (deprecated; kept for backward compatibility) ---
LMSTUDIO_MODE=llm
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=gemma-4-e4b-it
# LMSTUDIO_API_TOKEN=
# LMSTUDIO_VISION_MODEL=
# LMSTUDIO_SUPPORTS_VISION=auto

# Legacy flat RAG settings (used by existing lexical RAG path)
RAG_TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Log assembled prompts to stderr when true
DEBUG_PROMPTS=false
