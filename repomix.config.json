{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-output.xml"
  },
  "ignore": {
    "customPatterns": [
      "**/node_modules/**",
      "**/package-lock.json",
      "**/yarn.lock",
      "**/pnpm-lock.yaml",
      "web/dist/**",
      "**/__pycache__/**",
      "**/*.pyc",
      "**/*.pyo",
      "docs/**",
      "eval/**",
      ".cursor/**",
      "logs/**",
      "**/*.log",
      ".pytest-tmp/**",
      ".pytest_cache/**"
    ]
  }
}
