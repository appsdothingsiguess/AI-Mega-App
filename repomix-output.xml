          <span style={styles.modalTitle}>Settings</span>
          <button style={styles.closeBtn} onClick={onClose} type="button">×</button>
        </div>
        {error && <div style={styles.errorBanner}>{error}</div>}
        {serverNote && <div style={styles.warnBanner}>{serverNote}</div>}
        <div style={styles.body}>
          <section>
            <div style={styles.sectionTitle}>LM Studio</div>
            <div style={styles.lmNote}>
              Load and switch models in <strong>LM Studio</strong>. Prompter uses whichever
              model is currently loaded there.
            </div>
            <div style={styles.statusBox}>
              <div style={styles.statusRow}>
                <span style={styles.statusLabel}>Loaded model</span>
                <span style={{ color: lmHealth?.model_loaded ? "var(--success)" : "var(--warning)", fontFamily: "var(--font-mono)", fontSize: 12 }}>
                  {lmHealth?.model_loaded ? lmHealth.model : "None — load a model in LM Studio"}
                </span>
              </div>
              <div style={styles.statusRow}>
                <span style={styles.statusLabel}>API version</span>
                <span style={styles.statusValue}>{apiVersion}</span>
              </div>
              {lmHealth?.message && <div style={styles.statusHint}>{lmHealth.message}</div>}
            </div>
            <Field label="Server URL">
              <input style={styles.input} value={form.lmstudio_base_url ?? ""} onChange={(e) => set("lmstudio_base_url", e.target.value)} placeholder="http://localhost:1234" />
              {lanUrls.length > 0 && (
                <div style={styles.hint}>
                  LAN URLs:
                  <div style={{ display: "flex", flexWrap: "wrap", gap: 6, marginTop: 6 }}>
                    {lanUrls.map((url) => (
                      <button key={url} type="button" style={styles.urlChip} onClick={() => set("lmstudio_base_url", url)}>{url}</button>
                    ))}
                  </div>
                </div>
              )}
            </Field>
            <Field label="Serve on local network">
              <label style={styles.checkLabel}>
                <input type="checkbox" checked={server?.serve_on_local_network ?? false} disabled={networkSaving} onChange={(e) => handleNetworkToggle(e.target.checked)} style={{ accentColor: "var(--accent)" }} />
                <span style={{ color: "var(--text-muted)", fontSize: 12 }}>Allow LAN access to LM Studio</span>
              </label>
              <div style={styles.hint}>Restart the LM Studio server after toggling.</div>
            </Field>
            <Field label="API mode">
              <select style={styles.select} value={form.lmstudio_mode ?? "llm"} onChange={(e) => set("lmstudio_mode", e.target.value)}>
                <option value="llm">llm — native v1 (recommended)</option>
                <option value="rest">rest — OpenAI-compatible</option>
              </select>
            </Field>
          </section>
          <section>
            <div style={styles.sectionTitle}>Vision</div>
            <Field label="Vision model override">
              <input style={styles.input} value={form.lmstudio_vision_model ?? ""} onChange={(e) => set("lmstudio_vision_model", e.target.value.trim() || undefined)} placeholder="Empty = use loaded chat model" />
            </Field>
            <Field label="Vision support">
              <select style={styles.select} value={form.lmstudio_supports_vision ?? "auto"} onChange={(e) => set("lmstudio_supports_vision", e.target.value)}>
                <option value="auto">auto-detect</option>
                <option value="true">always on</option>
                <option value="false">always off</option>
              </select>
            </Field>
          </section>
          <section>
            <div style={styles.sectionTitle}>RAG</div>
            <Field label="Top-K"><input style={{ ...styles.input, width: 80 }} type="number" value={form.rag_top_k ?? 5} onChange={(e) => set("rag_top_k", Number(e.target.value))} /></Field>
            <Field label="Chunk size"><input style={{ ...styles.input, width: 100 }} type="number" value={form.chunk_size ?? 800} onChange={(e) => set("chunk_size", Number(e.target.value))} /></Field>
            <Field label="Overlap"><input style={{ ...styles.input, width: 100 }} type="number" value={form.chunk_overlap ?? 120} onChange={(e) => set("chunk_overlap", Number(e.target.value))} /></Field>
          </section>
          <section>
            <div style={styles.sectionTitle}>Advanced</div>
            <Field label="Debug prompts">
              <label style={styles.checkLabel}>
                <input type="checkbox" checked={form.debug_prompts ?? false} onChange={(e) => set("debug_prompts", e.target.checked)} />
                <span style={{ color: "var(--text-muted)", fontSize: 12 }}>Log prompts to stderr</span>
              </label>
            </Field>
          </section>
        </div>
        <div style={styles.footer}>
          <button style={styles.cancelBtn} onClick={onClose} type="button">Close</button>
          <button type="button" style={{ ...styles.saveBtn, ...(saved ? styles.savedBtn : {}) }} onClick={handleSave} disabled={saving}>{saving ? "Saving…" : saved ? "Saved" : "Save"}</button>
        </div>
      </div>
    </div>
  );
}

function Field({ label, children }: { label: string; children: React.ReactNode }) {
  return (
    <div style={{ marginBottom: 12 }}>
      <div style={{ fontSize: 11, color: "var(--text-muted)", marginBottom: 4 }}>{label}</div>
      {children}
    </div>
