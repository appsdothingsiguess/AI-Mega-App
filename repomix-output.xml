<file path="web/src/components/SettingsModal.tsx">
import { useCallback, useEffect, useMemo, useState } from "react";
import {
  getSettings,
  updateSettings,
  getLmServer,
  updateLmServer,
  health,
  SettingsSnapshot,
  SettingsUpdate,
  LmServerStatus,
  HealthResponse,
} from "../api/client";

interface Props {
  onClose: () => void;
}

const API_VERSION_LABEL: Record<string, string> = {
  llm: "v1 native (/api/v1/chat)",
  rest: "OpenAI-compatible (/v1/chat/completions)",
};

export default function SettingsModal({ onClose }: Props) {
  const [snap, setSnap] = useState<SettingsSnapshot | null>(null);
  const [form, setForm] = useState<SettingsUpdate>({});
  const [saving, setSaving] = useState(false);
  const [saved, setSaved] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const [lmHealth, setLmHealth] = useState<HealthResponse | null>(null);
  const [server, setServer] = useState<LmServerStatus | null>(null);
  const [serverNote, setServerNote] = useState<string | null>(null);
  const [networkSaving, setNetworkSaving] = useState(false);

  const refreshServer = useCallback(async () => {
    try {
      setServer(await getLmServer());
    } catch {
      setServer(null);
    }
  }, []);

  const refreshHealth = useCallback(async () => {
    try {
      setLmHealth(await health());
    } catch {
      setLmHealth(null);
    }
  }, []);

  useEffect(() => {
    getSettings()
      .then((s) => {
        setSnap(s);
        setForm({
          lmstudio_base_url: s.lmstudio_base_url,
          lmstudio_mode: s.lmstudio_mode,
          lmstudio_vision_model: s.lmstudio_vision_model ?? undefined,
          lmstudio_supports_vision: s.lmstudio_supports_vision,
          rag_top_k: s.rag_top_k,
          chunk_size: s.chunk_size,
          chunk_overlap: s.chunk_overlap,
          debug_prompts: s.debug_prompts,
        });
      })
      .catch((e: unknown) => {
        setError(e instanceof Error ? e.message : "Failed to load settings");
      });
    refreshServer();
    refreshHealth();
  }, [refreshServer, refreshHealth]);

  const set = <K extends keyof SettingsUpdate>(key: K, value: SettingsUpdate[K]) =>
    setForm((f) => ({ ...f, [key]: value }));

  const handleNetworkToggle = async (enabled: boolean) => {
    setNetworkSaving(true);
    setServerNote(null);
    setError(null);
    try {
      const updated = await updateLmServer(enabled);
      setServer(updated);
      setServerNote(updated.restart_required_note);
    } catch (e: unknown) {
      setError(e instanceof Error ? e.message : "Could not update network setting");
    } finally {
      setNetworkSaving(false);
    }
  };

  const handleSave = async () => {
    setSaving(true);
    setError(null);
    try {
      const updated = await updateSettings(form);
      setSnap(updated);
      setSaved(true);
      setTimeout(() => setSaved(false), 2000);
      await refreshHealth();
    } catch (e: unknown) {
      setError(e instanceof Error ? e.message : "Save failed");
    } finally {
      setSaving(false);
    }
  };

  const lanUrls = useMemo(() => {
    if (!server?.serve_on_local_network) return [];
    return server.access_urls.filter((u) => !u.includes("127.0.0.1"));
  }, [server]);

  const apiVersion =
    API_VERSION_LABEL[form.lmstudio_mode ?? "llm"] ?? form.lmstudio_mode;

  return (
