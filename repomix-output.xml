"""Layered settings: .env < data/settings.local.json < actual env vars.

The web UI reads/writes `data/settings.local.json`.  Secrets (LMSTUDIO_API_TOKEN)
stay in .env and are never touched here.
"""

from __future__ import annotations

import json
import os
from pathlib import Path
from typing import Any

from app.config import get_settings

# Keys that can be stored in local.json and their matching env var names.
_KEY_TO_ENV: dict[str, str] = {
    "lmstudio_base_url": "LMSTUDIO_BASE_URL",
    "lmstudio_mode": "LMSTUDIO_MODE",
    "lmstudio_model": "LMSTUDIO_MODEL",
    "lmstudio_vision_model": "LMSTUDIO_VISION_MODEL",
    "lmstudio_supports_vision": "LMSTUDIO_SUPPORTS_VISION",
    "rag_top_k": "RAG_TOP_K",
    "chunk_size": "CHUNK_SIZE",
    "chunk_overlap": "CHUNK_OVERLAP",
    "debug_prompts": "DEBUG_PROMPTS",
}

_LOCAL_FILE = Path("data/settings.local.json")


def _local_file() -> Path:
    """Return path to local settings file, resolving from cwd."""
    return _LOCAL_FILE


def load_local_settings() -> dict[str, Any]:
    """Return persisted local settings (empty dict if file missing)."""
    f = _local_file()
    if f.exists():
        try:
            return json.loads(f.read_text(encoding="utf-8"))
        except (json.JSONDecodeError, OSError):
            return {}
    return {}


def _apply_to_env(data: dict[str, Any]) -> None:
    """Push settings dict values into os.environ so pydantic-settings picks them up."""
    for key, value in data.items():
        env_key = _KEY_TO_ENV.get(key)
        if env_key is None:
            continue
        if isinstance(value, bool):
            os.environ[env_key] = "true" if value else "false"
        elif value is None:
            os.environ.pop(env_key, None)
        else:
            os.environ[env_key] = str(value)


def init_settings_store() -> None:
    """Call at app startup: load local settings and inject into env."""
    data = load_local_settings()
    _apply_to_env(data)


def save_local_settings(updates: dict[str, Any]) -> None:
    """Merge *updates* into local.json, push to env, clear settings cache."""
    f = _local_file()
    f.parent.mkdir(parents=True, exist_ok=True)
    existing = load_local_settings()
    # Remove None values from updates (explicit None = delete key)
    for k, v in list(updates.items()):
        if v is None:
            existing.pop(k, None)
        else:
            existing[k] = v
    f.write_text(json.dumps(existing, indent=2, ensure_ascii=False), encoding="utf-8")
    _apply_to_env(updates)
    # get_settings may be monkey-patched in tests (no cache_clear); be defensive.
    clear = getattr(get_settings, "cache_clear", None)
    if clear is not None:
        clear()
